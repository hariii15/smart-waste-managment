// Firebase Firestore Security Rules for Smart Waste Management
// These rules allow read/write access for development purposes
// In production, you should implement proper authentication and authorization

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.role == 'admin';
    }

    // Users collection (profiles + roles)
    match /users/{uid} {
      // Users can read their own profile
      allow read: if signedIn() && request.auth.uid == uid;

      // Users can create their own profile doc
      allow create: if signedIn() && request.auth.uid == uid;

      // Users can update their own non-role fields; role needs admin
      allow update: if signedIn() && request.auth.uid == uid && !('role' in request.resource.data.diff(resource.data).affectedKeys());
      allow update: if isAdmin();

      allow delete: if isAdmin();
    }

    // Allow read/write access to bins collection
    match /bins/{binId} {
      allow read, write: if true; // For development - open access
      // In production, you might want:
      // allow read: if true; // Public read access for display
      // allow write: if request.auth != null; // Only authenticated users can write
    }

    // Allow read/write access to routes collection  
    match /routes/{routeId} {
      allow read, write: if true; // For development - open access
      // In production, you might want:
      // allow read: if request.auth != null && request.auth.token.role == 'driver';
      // allow write: if request.auth != null && request.auth.token.role == 'admin';
    }

    // Allow read/write access to userReports collection
    match /userReports/{reportId} {
      allow read, write: if true; // For development - open access  
      // In production, you might want:
      // allow read: if request.auth != null;
      // allow create: if true; // Anyone can create reports
      // allow update, delete: if request.auth != null && request.auth.token.role == 'admin';
    }

    // Default rule: deny access to all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
