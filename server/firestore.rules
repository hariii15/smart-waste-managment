// Firebase Firestore Security Rules for Smart Waste Management
// These rules allow read/write access for development purposes
// In production, you should implement proper authentication and authorization

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    // Role is read from the user's profile doc (no custom claims required)
    function role() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isUser() {
      return signedIn() && (role() == 'user' || role() == 'driver' || role() == 'admin');
    }

    function isAdmin() {
      return signedIn() && role() == 'admin';
    }

    function isDriver() {
      return signedIn() && (role() == 'driver' || role() == 'admin');
    }

    // Users collection (profiles + roles)
    match /users/{uid} {
      // Prevent leaking the full user list to regular users.
      // Admin can list/read all; user can read self.
      allow list: if isAdmin();
      allow get: if signedIn() && request.auth.uid == uid;

      // Users can create their own profile doc
      allow create: if signedIn() && request.auth.uid == uid;

      // Users can update their own non-role fields
      allow update: if signedIn() && request.auth.uid == uid
        && !('role' in request.resource.data.diff(resource.data).affectedKeys());

      // Admin can update any user (including role / driverCode)
      allow update: if isAdmin();

      allow delete: if isAdmin();
    }

    // Public/limited stats documents for UI (e.g., show "number of drivers available")
    // Put aggregated numbers here instead of letting users query /users.
    match /stats/{docId} {
      // Any signed-in user can read stats for dynamic rendering.
      allow get, list: if isUser();
      // Only admin can write/update stats.
      allow create, update, delete: if isAdmin();
    }

    // Bins: only drivers/admins can read/write
    match /bins/{binId} {
      allow read, write: if isDriver();
    }

    // Routes: only drivers/admins can read/write
    match /routes/{routeId} {
      // Drivers/admins can read routes
      allow read: if isDriver();

      // Admins can write anything
      allow create, delete: if isAdmin();

      // Drivers can update only tracking/status fields (for their own assigned route)
      allow update: if isDriver()
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['driverLocation', 'status', 'updatedAt', 'resolvedAt', 'resolvedBy']);

      // Admin can update any field
      allow update: if isAdmin();
    }

    // Reports:
    // - Anyone signed-in can create
    // - Only drivers/admins can read/manage (so users can't see route/bin ops)
    match /userReports/{reportId} {
      allow create: if isUser();
      allow read, update, delete: if isDriver();
    }

    // Default rule: deny access to all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
